{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API (Node)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["--filter", "api", "dev"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Web (Next.js)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["--filter", "web", "dev"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        }
    ],
    "compounds": [
        {
            "name": "Evently (Full Stack)",
            "configurations": ["API (Node)", "Web (Next.js)"],
            "stopAll": true
        }
    ]
}
